logging {
  level  = "info"
  format = "json"
}

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}

loki.source.file "docker_logs" {
  targets = [
    { __path__ = "/var/lib/docker/containers/*/*.log" },
    { __path__ = "/var/log/syslog" },
  ]
  forward_to = [loki.write.local.receiver]
}